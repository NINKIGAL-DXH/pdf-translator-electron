{
  "name": "pdf-translator",
  "private": true,
  "version": "1.0.0",
  "type": "module",
  "main": "electron-main.cjs",
  "build": {
    "appId": "com.alter.pdftranslator",
    "productName": "PDF Translator",
    "directories": {
      "output": "dist-desktop"
    },
    "files": [
      "dist/**/*",
      "electron-main.cjs",
      "package.json"
    ],
    "mac": {
      "target": ["dmg"],
      "category": "public.app-category.productivity"
    }
  },
  "scripts": {
    "dev": "concurrently \"tsx server.ts\" \"vite\"",
    "build": "vite build && esbuild server.ts --bundle --platform=node --format=cjs --packages=external --sourcemap --outfile=dist/server.cjs",
    "start": "node dist/server.cjs",
    "electron:dev": "concurrently \"npm run dev\" \"wait-on http://localhost:5050 && electron .\"",
    "electron:build": "npm run build && electron-builder build --mac dmg --publish never"
  },
  "dependencies": {
    "@tailwindcss/vite": "^4.1.14",
    "@vitejs/plugin-react": "^5.0.4",
    "concurrently": "^9.1.2",
    "cors": "^2.8.5",
    "express": "^4.21.2",
    "lucide-react": "^0.546.0",
    "multer": "^1.4.5-lts.2",
    "pdfjs-dist": "^6.0.227",
    "react": "^19.0.1",
    "react-dom": "^19.0.1",
    "vite": "^6.2.3",
    "wait-on": "^8.0.3"
  },
  "devDependencies": {
    "@types/express": "^4.17.21",
    "@types/multer": "^1.4.12",
    "@types/node": "^22.14.0",
    "@types/react": "^19.0.0",
    "@types/react-dom": "^19.0.0",
    "autoprefixer": "^10.4.21",
    "electron": "^35.0.0",
    "electron-builder": "^26.0.12",
    "esbuild": "^0.25.0",
    "tailwindcss": "^4.1.14",
    "tsx": "^4.21.0",
    "typescript": "~5.8.2"
  }
}
